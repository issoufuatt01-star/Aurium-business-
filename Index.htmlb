<body>

...

<script src="https://cdn.jsdelivr.net/npm/appwrite@13.0.1"></script>
<script src="app.js"></script>

</body>

<!-- ================= AUTH ================= -->

<div class="auth-box" id="auth">

<div class="title">💎 Aurum Business</div>

<div class="input-group">
<label>Numéro de téléphone</label>
<input type="tel" id="phone" placeholder="+226 XX XX XX XX">
</div>

<div class="input-group">
<label>Mot de passe</label>
<input type="password" id="pass" placeholder="••••••••">
</div>

<div class="input-group">
<label>Pays</label>

<select id="country">

<option value="BF">🇧🇫 +226 Burkina Faso</option>
<option value="CI">🇨🇮 +225 Côte d'Ivoire</option>
<option value="ML">🇲🇱 +223 Mali</option>
<option value="SN">🇸🇳 +221 Sénégal</option>
<option value="CM">🇨🇲 +237 Cameroun</option>
<option value="TG">🇹🇬 +228 Togo</option>
<option value="BJ">🇧🇯 +229 Bénin</option>

</select>
</div>

<div class="input-group">
<label>Code de parrainage</label>
<input type="text" id="ref" placeholder="AURUM2026">
</div>

<button class="btn-primary" onclick="register()">
S'inscrire
</button>

<button class="btn-secondary" onclick="login()">
Connexion
</button>

<div class="small">
Aurum Business Pro © 2026
</div>

</div>

<!-- ================= APP ================= -->

<div id="app">

<div class="header">

<div class="logo">AURUM</div>

<div id="userId">
USER
</div>

</div>

<div id="home" class="page active"></div>
<div id="orders" class="page"></div>
<div id="team" class="page"></div>
<div id="me" class="page"></div>

<div class="nav">

<button onclick="showPage('home')">🏠</button>
<button onclick="showPage('orders')">🚀</button>
<button onclick="showPage('team')">👥</button>
<button onclick="showPage('me')">⚙️</button>

</div>

<button id="installBtn">
Installer App
</button>

</div>

<script>
/* ================= APPWRITE CONFIG ================= */

const {
Client,
Account,
Databases,
ID,
Query
} = Appwrite;

const client = new Client();

client
.setEndpoint('https://nyc.cloud.appwrite.io/v1')
.setProject('6a0745c500257a8ce2d7');

const account = new Account(client);

const databases = new Databases(client);

/* ================= DATABASE ================= */

const DATABASE_ID = "aurum_db";
const USERS_COLLECTION = "users";
const WITHDRAWALS_COLLECTION = "withdrawals";
const DEPOSITS_COLLECTION = "deposits";
const TRANSACTIONS_COLLECTION = "transactions";

/* ================= VARIABLES ================= */

const auth = document.getElementById("auth");
const app = document.getElementById("app");

const home = document.getElementById("home");
const ordersPage = document.getElementById("orders");
const teamPage = document.getElementById("team");
const mePage = document.getElementById("me");

const installBtn = document.getElementById("installBtn");

let users =
JSON.parse(localStorage.getItem("users")) || [];

let orders =
JSON.parse(localStorage.getItem("orders")) || [];

let transactions =
JSON.parse(localStorage.getItem("tx")) || [];

let user = null;

/* ================= INSTALL PWA ================= */

let deferredPrompt;

window.addEventListener(
"beforeinstallprompt",
(e)=>{

e.preventDefault();

deferredPrompt = e;

installBtn.style.display = "block";

}
);

installBtn.addEventListener(
"click",
async()=>{

if(!deferredPrompt) return;

deferredPrompt.prompt();

await deferredPrompt.userChoice;

installBtn.style.display = "none";

}
);

/* ================= REF LINK ================= */

window.addEventListener(
"load",
()=>{

let url = new URL(window.location.href);

let ref = url.searchParams.get("ref");

if(ref){

document.getElementById("ref").value = ref;

}

}
);

/* ================= PRODUITS PREMIUM ================= */

const products = [

{
  id:1,
  name:"VIP 1",
  subtitle:"Starter Premium",
  price:3000,
  daily:750,
  total:45000,
  duration:60,
  badge:"Populaire",
  color:"#d4af37",
  img:"https://images.unsplash.com/photo-1520607162513-77705c0f0d4a?q=80&w=1200&auto=format&fit=crop"
},

{
  id:2,
  name:"VIP 2",
  subtitle:"Gold Business",
  price:15000,
  daily:1440,
  total:43200,
  duration:30,
  badge:"Rentable",
  color:"#c9a227",
  img:"https://images.unsplash.com/photo-1559526324-593bc073d938?q=80&w=1200&auto=format&fit=crop"
},

{
  id:3,
  name:"VIP 3",
  subtitle:"Luxury Investor",
  price:40000,
  daily:19200,
  total:192000,
  duration:10,
  badge:"VIP",
  color:"#e5c158",
  img:"https://images.unsplash.com/photo-1518546305927-5a555bb7020d?q=80&w=1200&auto=format&fit=crop"
},

{
  id:4,
  name:"VIP 4",
  subtitle:"Elite Premium",
  price:60000,
  daily:52800,
  total:528000,
  duration:10,
  badge:"Elite",
  color:"#f5d76e",
  img:"https://images.unsplash.com/photo-1521791136064-7986c2920216?q=80&w=1200&auto=format&fit=crop"
},

{
  id:5,
  name:"VIP 5",
  subtitle:"Diamond Plan",
  price:100000,
  daily:84000,
  total:840000,
  duration:10,
  badge:"Diamond",
  color:"#ffd700",
  img:"https://images.unsplash.com/photo-1556740749-887f6717d7e4?q=80&w=1200&auto=format&fit=crop"
},

{
  id:6,
  name:"VIP 6",
  subtitle:"Executive Club",
  price:200000,
  daily:129984,
  total:1299840,
  duration:10,
  badge:"Executive",
  color:"#ffcc33",
  img:"https://images.unsplash.com/photo-1522202176988-66273c2fd55f?q=80&w=1200&auto=format&fit=crop"
},

{
  id:7,
  name:"VIP 7",
  subtitle:"Royal Investor",
  price:350000,
  daily:246720,
  total:2467200,
  duration:10,
  badge:"Royal",
  color:"#f0b90b",
  img:"https://images.unsplash.com/photo-1507679799987-c73779587ccf?q=80&w=1200&auto=format&fit=crop"
},

{
  id:8,
  name:"VIP 8",
  subtitle:"Prestige Max",
  price:550000,
  daily:412488,
  total:4124880,
  duration:10,
  badge:"Prestige",
  color:"#f7c948",
  img:"https://images.unsplash.com/photo-1486406146926-c627a92ad1ab?q=80&w=1200&auto=format&fit=crop"
},

{
  id:9,
  name:"VIP 9",
  subtitle:"Imperial Gold",
  price:800000,
  daily:600000,
  total:6000000,
  duration:10,
  badge:"Imperial",
  color:"#ffdf6c",
  img:"https://images.unsplash.com/photo-1460317442991-0ec209397118?q=80&w=1200&auto=format&fit=crop"
},

{
  id:10,
  name:"VIP 10",
  subtitle:"Ultimate Emirates",
  price:1000000,
  daily:800400,
  total:8004000,
  duration:10,
  badge:"Ultra VIP",
  color:"#ffb703",
  img:"https://images.unsplash.com/photo-1497366754035-f200968a6e72?q=80&w=1200&auto=format&fit=crop"
}

];

/* ================= AUTH ================= */

function register(){

let phone =
document.getElementById("phone").value.trim();

let pass =
document.getElementById("pass").value.trim();

let ref =
document.getElementById("ref").value.trim();

if(!phone || !pass){

alert("Veuillez remplir les champs");
return;

}

if(users.find(u=>u.phone===phone)){

alert("Compte déjà existant");
return;

}

let newUser = {

id:Date.now(),

phone:phone,

password:pass,

balance:5000,

code:"AI"+Math.random().toString(36).substr(2,8),

referrer:ref

};

users.push(newUser);

save();

alert("Compte créé avec succès");

}

/* ================= LOGIN ================= */

function login(){

let phone =
document.getElementById("phone").value;

let pass =
document.getElementById("pass").value;

let u = users.find(
x=>x.phone===phone && x.password===pass
);

if(!u){

alert("Identifiants incorrects");
return;

}

user = u;

auth.style.display = "none";

app.style.display = "block";

document.getElementById("userId").innerText =
user.phone;

renderAll();

}

/* ================= SHOW PAGE ================= */

function showPage(page){

document.querySelectorAll(".page")
.forEach(p=>p.classList.remove("active"));

document.getElementById(page)
.classList.add("active");

}

/* ================= HOME ================= */

function renderHome(){

let gains = transactions
.filter(t=>t.user_id===user.id && t.type==="gain")
.reduce((s,t)=>s+t.amount,0);

home.innerHTML = `

<img class="banner"
src="https://mir-s3-cdn-cf.behance.net/project_modules/max_1200/5e342a106822209.5f992383e20e8.jpg">

<div class="balance-box">

<p>Solde disponible</p>

<h1 id="balance">
${user.balance.toLocaleString()} FCFA
</h1>

<div class="vip-status" id="vipStatus">
Compte VIP Actif
</div>

</div>

<div class="revenue-box">

<span>Revenus cumulés</span>

<b>${gains.toLocaleString()} FCFA</b>

</div>

<div class="action-grid">

<div class="action-btn" onclick="deposit()">
💳<br>Dépôt
</div>

<div class="action-btn" onclick="withdraw()">
🏧<br>Retrait
</div>

<div class="action-btn" onclick="showPage('orders')">
🚀<br>VIP
</div>

<div class="action-btn" onclick="showPage('team')">
👥<br>Équipe
</div>

</div>

`;

products.forEach((p,i)=>{

home.innerHTML += `

<div class="card">

<img src="${p.img}">

<div class="card-content">

<h3>${p.name}</h3>

<div class="grid-info">

<p>Prix : <b>${p.price} F</b></p>

<p>Durée : <b>${p.duration}j</b></p>

<p>Total : <b>${p.total} F</b></p>

<p>Jour : <b>${p.daily} F</b></p>

</div>

<button class="btn-primary"
onclick="buy(${i})">

Activer l'investissement

</button>

</div>

</div>

`;

});

}

/* ================= ACHAT MLM ================= */

function buy(i){

let p = products[i];

if(user.balance < p.price){

alert("Solde insuffisant");
return;

}

user.balance -= p.price;

orders.push({

id:Date.now(),

user_id:user.id,

product:p.name,

daily:p.daily,

last:0

});

/* ===== MLM ===== */

let u1 =
users.find(u=>u.code===user.referrer);

if(u1){

let g1 = p.price * 0.27;

u1.balance += g1;

transactions.push({
user_id:u1.id,
type:"niveau1",
amount:g1
});

let u2 =
users.find(u=>u.code===u1.referrer);

if(u2){

let g2 = p.price * 0.02;

u2.balance += g2;

transactions.push({
user_id:u2.id,
type:"niveau2",
amount:g2
});

let u3 =
users.find(u=>u.code===u2.referrer);

if(u3){

let g3 = p.price * 0.01;

u3.balance += g3;

transactions.push({
user_id:u3.id,
type:"niveau3",
amount:g3
});

}

}

}

save();

renderAll();

alert("VIP activé");

}

/* ================= ORDERS ================= */

function renderOrders(){

let myOrders =
orders.filter(o=>o.user_id===user.id);

ordersPage.innerHTML =
"<h2>Mes investissements</h2><br>";

if(myOrders.length===0){

ordersPage.innerHTML +=
"Aucun investissement actif";

return;

}

myOrders.forEach(o=>{

ordersPage.innerHTML += `

<div class="card">

<div class="card-content">

<h3>${o.product}</h3>

<p>Gain journalier :
<b>${o.daily} FCFA</b></p>

<button class="btn-primary"
onclick="claim(${o.id})">

Réclamer le gain

</button>

</div>

</div>

`;

});

}

/* ================= CLAIM ================= */

function claim(id){

let order =
orders.find(o=>o.id===id);

if(Date.now() - order.last < 86400000){

alert("Déjà réclamé aujourd'hui");
return;

}

order.last = Date.now();

user.balance += order.daily;

transactions.push({

user_id:user.id,

type:"gain",

amount:order.daily

});

save();

renderAll();

}

/* ================= TEAM ================= */

function renderTeam(){

let l1 =
users.filter(u=>u.referrer===user.code);

let l2 =
users.filter(u=>l1.find(x=>x.code===u.referrer));

let l3 =
users.filter(u=>l2.find(x=>x.code===u.referrer));

let link =
window.location.origin +
window.location.pathname +
"?ref=" + user.code;

teamPage.innerHTML = `

<div class="card">

<div class="card-content">

<h3>Mon lien d'invitation</h3>

<p style="margin:10px 0; word-break:break-all;">
${link}
</p>

<button class="btn-primary"
onclick="copyLink('${link}')">

Copier mon lien

</button>

<br><br>

<p>L1 : ${l1.length}</p>
<p>L2 : ${l2.length}</p>
<p>L3 : ${l3.length}</p>

</div>

</div>

`;

}

/* ================= PAGE ME ================= */

function renderMe(){

mePage.innerHTML = `

<div class="profile-card">

<div class="avatar">👤</div>

<h2 style="margin-top:15px;">
${user.phone}
</h2>

<p>Membre Gold Premium</p>

</div>

<div class="menu">

<div class="menu-item"
onclick="deposit()">

<span>💳 Dépôt</span>

<span>›</span>

</div>

<div class="menu-item"
onclick="withdraw()">

<span>🏧 Retrait</span>

<span>›</span>

</div>

<div class="menu-item"
onclick="window.open('https://t.me/Tradingoold')">

<span>✈️ Support Télégram</span>

<span>›</span>

</div>

<div class="menu-item"
onclick="window.open('https://t.me/Tradingoold')">

<span>👥 Communauté</span>

<span>›</span>

</div>

<div class="menu-item"
