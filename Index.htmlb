
<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Aurum Business Pro</title>

<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">

<style>/* ================= CARD PRODUITS PREMIUM ================= */

.product-card{
  position:relative;
  overflow:hidden;
  border-radius:22px;
  background:#111;
  margin-bottom:20px;
  box-shadow:0 10px 35px rgba(0,0,0,0.25);
  transition:0.3s;
}

.product-card:hover{
  transform:translateY(-5px);
}

.product-card img{
  width:100%;
  height:220px;
  object-fit:cover;
  display:block;
  filter:brightness(0.88);
}

.product-overlay{
  position:absolute;
  inset:0;
  background:linear-gradient(
    to top,
    rgba(0,0,0,0.85),
    rgba(0,0,0,0.15)
  );
}

.product-content{
  position:absolute;
  bottom:0;
  left:0;
  width:100%;
  padding:20px;
  color:#fff;
}

.product-badge{
  position:absolute;
  top:15px;
  right:15px;
  background:gold;
  color:#111;
  font-size:12px;
  font-weight:700;
  padding:6px 14px;
  border-radius:30px;
}

.product-title{
  font-size:26px;
  font-weight:700;
  margin-bottom:5px;
}

.product-subtitle{
  font-size:14px;
  opacity:0.9;
  margin-bottom:15px;
}

.product-info{
  display:flex;
  justify-content:space-between;
  margin-bottom:12px;
  font-size:14px;
}

.product-price{
  font-size:24px;
  font-weight:700;
  color:gold;
}

.buy-btn{
  width:100%;
  border:none;
  padding:14px;
  border-radius:14px;
  background:linear-gradient(135deg,#d4af37,#f7d774);
  color:#111;
  font-weight:700;
  font-size:16px;
  cursor:pointer;
  transition:0.3s;
}

.buy-btn:hover{
  transform:scale(1.02);
}

/* ================= GLOBAL ================= */

*{
    margin:0;
    padding:0;
    box-sizing:border-box;
    font-family:'Poppins',sans-serif;
}

body{
    background:linear-gradient(135deg,#001f4d,#0a2a5c,#d4a437);
    min-height:100vh;
    display:flex;
    justify-content:center;
    align-items:center;
    overflow-x:hidden;
}

/* ================= AUTH ================= */

.auth-box{
    width:100%;
    max-width:420px;
    background:rgba(15,23,42,0.97);
    padding:25px;
    border-radius:20px;
    box-shadow:0 20px 40px rgba(0,0,0,0.4);
}

.title{
    text-align:center;
    font-size:28px;
    color:#f5c542;
    font-weight:700;
    margin-bottom:25px;
}

.input-group{
    display:flex;
    flex-direction:column;
    margin-bottom:15px;
}

.input-group label{
    margin-bottom:6px;
    color:#cbd5e1;
    font-size:13px;
}

.input-group input,
.input-group select{
    padding:14px;
    border:none;
    border-radius:12px;
    background:#1e293b;
    color:#fff;
    font-size:14px;
    outline:none;
}

.input-group input:focus,
.input-group select:focus{
    border:1px solid #f5c542;
    background:#111827;
}

button{
    width:100%;
    padding:14px;
    border:none;
    border-radius:14px;
    cursor:pointer;
    font-weight:700;
    margin-top:10px;
    transition:0.3s;
}

button:hover{
    transform:scale(1.02);
}

.btn-primary{
    background:linear-gradient(135deg,#d4a437,#f7d774);
    color:#000;
}

.btn-secondary{
    background:#0f172a;
    color:#fff;
}

.small{
    text-align:center;
    margin-top:15px;
    font-size:12px;
    color:#94a3b8;
}

/* ================= APP ================= */

#app{
    display:none;
    width:100%;
    max-width:500px;
    min-height:100vh;
    background:#f5f7fb;
    color:#111;
    position:relative;
}

/* ================= HEADER ================= */

.header{
    background:#0f172a;
    color:#fff;
    padding:18px;
    display:flex;
    justify-content:space-between;
    align-items:center;
    position:sticky;
    top:0;
    z-index:999;
}

.logo{
    color:#f5c542;
    font-size:22px;
    font-weight:700;
}

/* ================= PAGE ================= */

.page{
    display:none;
    padding:15px;
    padding-bottom:100px;
}

.page.active{
    display:block;
}

/* ================= HOME ================= */

.banner{
    width:100%;
    border-radius:18px;
    margin-bottom:15px;
}

.balance-box{
    background:linear-gradient(135deg,#0f172a,#1e293b);
    color:#fff;
    padding:20px;
    border-radius:18px;
    margin-bottom:15px;
}

.balance-box p{
    font-size:13px;
    opacity:0.8;
}

.balance-box h1{
    margin-top:10px;
    font-size:30px;
}

.vip-status{
    margin-top:12px;
    background:#14b85a;
    padding:8px;
    border-radius:10px;
    text-align:center;
    font-size:13px;
    font-weight:600;
}

.revenue-box{
    background:#fff;
    border-radius:15px;
    padding:15px;
    margin-bottom:15px;
    display:flex;
    justify-content:space-between;
    box-shadow:0 5px 15px rgba(0,0,0,0.05);
}

.action-grid{
    display:grid;
    grid-template-columns:repeat(4,1fr);
    gap:10px;
    margin-bottom:20px;
}

.action-btn{
    background:#fff;
    padding:15px;
    border-radius:14px;
    text-align:center;
    font-size:13px;
    cursor:pointer;
    box-shadow:0 5px 10px rgba(0,0,0,0.05);
}

/* ================= CARD ================= */

.card{
    background:#fff;
    border-radius:18px;
    overflow:hidden;
    margin-bottom:15px;
    box-shadow:0 5px 15px rgba(0,0,0,0.05);
}

.card img{
    width:100%;
    height:180px;
    object-fit:cover;
}

.card-content{
    padding:15px;
}

.card-content h3{
    margin-bottom:10px;
}

.grid-info{
    display:grid;
    grid-template-columns:1fr 1fr;
    gap:10px;
    font-size:13px;
    color:#555;
}

/* ================= PROFILE ================= */

.profile-card{
    background:#fff;
    border-radius:20px;
    padding:25px;
    text-align:center;
    margin-bottom:15px;
}

.avatar{
    width:80px;
    height:80px;
    border-radius:50%;
    background:#f5c542;
    display:flex;
    justify-content:center;
    align-items:center;
    font-size:35px;
    margin:auto;
}

.menu{
    background:#fff;
    border-radius:18px;
    overflow:hidden;
}

.menu-item{
    display:flex;
    justify-content:space-between;
    padding:16px;
    border-bottom:1px solid #eee;
    cursor:pointer;
}

/* ================= NAV ================= */

.nav{
    position:fixed;
    bottom:0;
    left:50%;
    transform:translateX(-50%);
    width:100%;
    max-width:500px;
    background:#fff;
    display:grid;
    grid-template-columns:repeat(4,1fr);
    border-top:1px solid #ddd;
}

.nav button{
    background:none;
    color:#0f172a;
    font-size:22px;
}

/* ================= INSTALL BUTTON ================= */

#installBtn{
    position:fixed;
    bottom:90px;
    right:20px;
    width:auto;
    padding:12px 18px;
    border-radius:50px;
    background:#f5c542;
    color:#000;
    font-weight:700;
    display:none;
}
                                  </style>
